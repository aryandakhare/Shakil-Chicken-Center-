<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shakil Chicken Shop Chimur | Fresh Chicken Delivered</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');
        :root {
            --primary: #d32f2f;
        }
        * {
            font-family: 'Poppins', sans-serif;
        }
        .logo-text {
            font-size: 2rem;
            font-weight: 700;
            color: #d32f2f;
        }
        .hero-bg {
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://picsum.photos/id/1015/1920/1080') center/cover no-repeat;
        }
        .product-card {
            transition: all 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
        }
        .nav-link {
            position: relative;
        }
        .nav-link:after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #d32f2f;
            transition: all 0.3s;
        }
        .nav-link:hover:after {
            width: 100%;
        }
        .modal {
            animation: modalPop 0.3s ease;
        }
        @keyframes modalPop {
            0% { transform: scale(0.95); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
        .section {
            display: none;
        }
        .section.active {
            display: block;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
    <!-- NAVBAR -->
    <nav class="bg-white border-b shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-red-600 rounded-2xl flex items-center justify-center text-white text-2xl shadow-inner">
                        🐔
                    </div>
                    <div>
                        <h1 class="logo-text tracking-tighter">Shakil Chicken</h1>
                        <p class="text-xs text-gray-500 -mt-1 font-medium">CHIMUR • Since 2015</p>
                    </div>
                </div>

                <!-- Menu -->
                <div class="hidden md:flex items-center gap-8 text-sm font-medium">
                    <a onclick="navigateTo('home')" class="nav-link cursor-pointer text-gray-700 hover:text-red-600">Home</a>
                    <a onclick="navigateTo('shop')" class="nav-link cursor-pointer text-gray-700 hover:text-red-600">Shop</a>
                    <a onclick="navigateTo('cart')" class="nav-link cursor-pointer text-gray-700 hover:text-red-600 flex items-center gap-1">
                        <i class="fas fa-shopping-cart"></i>
                        Cart <span id="cart-count" class="bg-red-600 text-white text-xs px-2 py-0.5 rounded-full">0</span>
                    </a>
                    <a onclick="navigateTo('orders')" class="nav-link cursor-pointer text-gray-700 hover:text-red-600">My Orders</a>
                    <a onclick="navigateTo('bulk')" class="nav-link cursor-pointer text-gray-700 hover:text-red-600">Bulk Order</a>
                    
                    <!-- Auth Status -->
                    <div id="auth-section" class="flex items-center gap-4">
                        <button onclick="showLoginModal()" 
                                id="login-btn"
                                class="px-5 py-2 text-sm font-semibold border border-red-600 text-red-600 rounded-2xl hover:bg-red-600 hover:text-white transition">
                            Login
                        </button>
                        <button onclick="logout()" 
                                id="logout-btn"
                                class="hidden px-5 py-2 text-sm font-semibold bg-red-600 text-white rounded-2xl hover:bg-red-700 transition">
                            Logout
                        </button>
                        <div onclick="showProfile()" id="user-avatar" class="hidden w-8 h-8 bg-red-100 text-red-600 rounded-2xl flex items-center justify-center cursor-pointer font-bold text-lg">
                            A
                        </div>
                    </div>
                </div>

                <!-- Mobile Menu Button -->
                <button onclick="toggleMobileMenu()" class="md:hidden text-2xl text-gray-700">
                    <i class="fas fa-bars" id="mobile-icon"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t px-6 py-4">
            <div class="flex flex-col gap-4 text-sm font-medium">
                <a onclick="navigateTo('home');toggleMobileMenu()" class="py-2">Home</a>
                <a onclick="navigateTo('shop');toggleMobileMenu()" class="py-2">Shop</a>
                <a onclick="navigateTo('cart');toggleMobileMenu()" class="py-2">Cart</a>
                <a onclick="navigateTo('orders');toggleMobileMenu()" class="py-2">My Orders</a>
                <a onclick="navigateTo('bulk');toggleMobileMenu()" class="py-2">Bulk Order</a>
                <div class="pt-4 border-t">
                    <button onclick="showLoginModal();toggleMobileMenu()" id="mobile-login-btn"
                            class="w-full py-3 text-center font-semibold border border-red-600 text-red-600 rounded-2xl">Login</button>
                    <button onclick="logout();toggleMobileMenu()" id="mobile-logout-btn"
                            class="hidden w-full py-3 mt-2 text-center font-semibold bg-red-600 text-white rounded-2xl">Logout</button>
                </div>
            </div>
        </div>
    </nav>

    <!-- HOME SECTION -->
    <section id="home" class="section active">
        <div class="hero-bg h-screen flex items-center text-white">
            <div class="max-w-7xl mx-auto px-6">
                <div class="max-w-lg">
                    <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-md text-white text-sm px-6 py-2 rounded-3xl mb-6">
                        <span class="animate-pulse">●</span> Fresh from Chimur Farms
                    </div>
                    <h1 class="text-6xl font-bold leading-none tracking-tighter mb-4">
                        Premium Chicken<br>Delivered Fresh
                    </h1>
                    <p class="text-xl mb-8">Shakil Chicken Shop Chimur – Boiler ₹200/kg | Hydrabadi ₹380/kg | Koklere ₹180/kg | Gaorani ₹800/kg</p>
                    
                    <div class="flex gap-4">
                        <button onclick="navigateTo('shop')" 
                                class="bg-white text-red-600 font-semibold px-10 py-4 rounded-3xl text-lg hover:scale-105 transition flex items-center gap-3">
                            <i class="fas fa-store"></i>
                            Shop Now
                        </button>
                        <button onclick="navigateTo('bulk')" 
                                class="border-2 border-white font-semibold px-10 py-4 rounded-3xl text-lg hover:bg-white hover:text-red-600 transition">
                            Bulk Orders
                        </button>
                    </div>
                    
                    <div class="mt-12 flex items-center gap-8 text-sm">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-truck text-3xl"></i>
                            <div>
                                <div class="font-semibold">30 Min Delivery</div>
                                <div class="text-white/70">Chimur &amp; nearby areas</div>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <i class="fas fa-medal text-3xl"></i>
                            <div>
                                <div class="font-semibold">100% Fresh</div>
                                <div class="text-white/70">Halal Certified</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Trust Bar -->
        <div class="bg-white py-6 border-b">
            <div class="max-w-7xl mx-auto px-6 grid grid-cols-3 md:grid-cols-6 gap-6 text-center text-sm font-medium">
                <div class="flex flex-col items-center"><i class="fas fa-leaf text-4xl text-green-600 mb-2"></i> Farm Fresh</div>
                <div class="flex flex-col items-center"><i class="fas fa-shield-alt text-4xl text-blue-600 mb-2"></i> 100% Halal</div>
                <div class="flex flex-col items-center"><i class="fas fa-truck-fast text-4xl text-orange-600 mb-2"></i> Same Day Delivery</div>
                <div class="flex flex-col items-center"><i class="fas fa-rupee-sign text-4xl text-green-600 mb-2"></i> Best Prices</div>
                <div class="flex flex-col items-center"><i class="fas fa-star text-4xl text-yellow-500 mb-2"></i> 4.9/5 Rating</div>
                <div class="flex flex-col items-center"><i class="fas fa-users text-4xl text-purple-600 mb-2"></i> 10k+ Happy Customers</div>
            </div>
        </div>

        <!-- Featured Products Teaser -->
        <div class="max-w-7xl mx-auto px-6 py-12">
            <h2 class="text-3xl font-bold text-center mb-8">Our Premium Chicken Range</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6" id="featured-products">
                <!-- Populated by JS -->
            </div>
        </div>
    </section>

    <!-- SHOP SECTION -->
    <section id="shop" class="section">
        <div class="max-w-7xl mx-auto px-6 py-12">
            <h1 class="text-4xl font-bold mb-2">Shop Fresh Chicken</h1>
            <p class="text-gray-500 mb-8">Select quantity in kilograms • All prices per kg</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" id="products-grid">
                <!-- Populated by JS -->
            </div>
        </div>
    </section>

    <!-- CART SECTION -->
    <section id="cart" class="section">
        <div class="max-w-7xl mx-auto px-6 py-12">
            <h1 class="text-4xl font-bold mb-8 flex items-center gap-3">
                <i class="fas fa-shopping-cart"></i> Your Cart
            </h1>
            
            <div id="cart-empty" class="hidden text-center py-20">
                <i class="fas fa-shopping-bag text-7xl text-gray-300 mb-6"></i>
                <h3 class="text-2xl font-semibold mb-2">Cart is empty</h3>
                <p class="text-gray-500 mb-8">Add some fresh chicken from our shop!</p>
                <button onclick="navigateTo('shop')" class="bg-red-600 text-white px-10 py-4 rounded-3xl">Browse Products</button>
            </div>
            
            <div id="cart-content" class="hidden">
                <div class="bg-white rounded-3xl shadow p-8">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b text-left text-sm font-semibold text-gray-500">
                                <th class="pb-4">Item</th>
                                <th class="pb-4">Qty (kg)</th>
                                <th class="pb-4">Price/kg</th>
                                <th class="pb-4 text-right">Subtotal</th>
                                <th class="pb-4 w-10"></th>
                            </tr>
                        </thead>
                        <tbody id="cart-items" class="text-sm divide-y"></tbody>
                    </table>
                    
                    <div class="flex justify-between items-end mt-8">
                        <div>
                            <p class="text-gray-500">Total (incl. GST 5%)</p>
                            <p id="cart-total" class="text-5xl font-bold text-red-600">₹0</p>
                        </div>
                        <button onclick="proceedToCheckout()" 
                                class="bg-red-600 hover:bg-red-700 text-white px-12 py-5 rounded-3xl font-semibold text-lg flex items-center gap-3">
                            Proceed to Billing
                            <i class="fas fa-arrow-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CHECKOUT / BILLING SECTION -->
    <section id="checkout" class="section">
        <div class="max-w-4xl mx-auto px-6 py-12">
            <h1 class="text-4xl font-bold mb-2">Billing &amp; Checkout</h1>
            <p class="text-gray-500 mb-8">Complete your order • Cash on Delivery available</p>
            
            <div class="grid md:grid-cols-2 gap-12">
                <!-- Billing Form -->
                <div class="bg-white p-8 rounded-3xl shadow">
                    <h3 class="font-semibold text-lg mb-6">Delivery Details</h3>
                    <form id="billing-form" onsubmit="placeOrder(event)">
                        <div class="space-y-5">
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">Full Name</label>
                                <input type="text" id="name" value="Aryan" required
                                       class="w-full px-5 py-4 border rounded-2xl focus:outline-none focus:border-red-300">
                            </div>
                            <div class="grid grid-cols-2 gap-5">
                                <div>
                                    <label class="block text-xs font-medium text-gray-500 mb-1">Phone</label>
                                    <input type="tel" id="phone" value="9876543210" required
                                           class="w-full px-5 py-4 border rounded-2xl focus:outline-none focus:border-red-300">
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-gray-500 mb-1">Pincode</label>
                                    <input type="text" id="pincode" value="442904" required
                                           class="w-full px-5 py-4 border rounded-2xl focus:outline-none focus:border-red-300">
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-500 mb-1">Full Address</label>
                                <textarea id="address" rows="3" required
                                    class="w-full px-5 py-4 border rounded-3xl focus:outline-none focus:border-red-300">Shakil Chicken Shop Chimur, Near Bus Stand, Chimur, Maharashtra 442904</textarea>
                            </div>
                            
                            <div class="pt-4 border-t">
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" checked class="w-5 h-5 accent-red-600">
                                    <span class="text-sm">Cash on Delivery</span>
                                </label>
                            </div>
                            
                            <button type="submit"
                                    class="w-full bg-red-600 text-white py-5 rounded-3xl font-semibold text-xl mt-4 hover:bg-red-700 transition">
                                Place Order • Pay ₹<span id="checkout-total"></span>
                            </button>
                        </div>
                    </form>
                </div>
                
                <!-- Order Summary -->
                <div class="bg-white p-8 rounded-3xl shadow h-fit">
                    <h3 class="font-semibold text-lg mb-6">Order Summary</h3>
                    <div id="checkout-items" class="space-y-4"></div>
                    <div class="border-t pt-6 mt-6 text-sm">
                        <div class="flex justify-between mb-2"><span>Subtotal</span><span id="subtotal"></span></div>
                        <div class="flex justify-between mb-2"><span>GST (5%)</span><span id="gst"></span></div>
                        <div class="flex justify-between text-xl font-semibold"><span>Total</span><span id="final-total"></span></div>
                    </div>
                </div>
            </div>
            
            <button onclick="navigateTo('cart')" class="mt-8 text-gray-500 hover:text-gray-700 flex items-center gap-2">
                ← Back to Cart
            </button>
        </div>
    </section>

    <!-- ORDERS SECTION -->
    <section id="orders" class="section">
        <div class="max-w-7xl mx-auto px-6 py-12">
            <h1 class="text-4xl font-bold mb-8">My Orders</h1>
            <div id="orders-list" class="space-y-6">
                <!-- Populated by JS -->
            </div>
        </div>
    </section>

    <!-- BULK ORDER SECTION -->
    <section id="bulk" class="section">
        <div class="max-w-4xl mx-auto px-6 py-16">
            <div class="text-center mb-12">
                <h1 class="text-5xl font-bold mb-3">Bulk Order Special</h1>
                <p class="max-w-md mx-auto text-gray-600">For hotels, restaurants, caterers &amp; parties. Minimum 50 kg</p>
            </div>
            
            <form onsubmit="submitBulkOrder(event)" class="bg-white rounded-3xl shadow-xl p-10">
                <div class="grid md:grid-cols-2 gap-8">
                    <div>
                        <label class="block text-sm font-medium mb-2">Your Name / Business</label>
                        <input id="bulk-name" type="text" value="Aryan Catering" required
                               class="w-full px-6 py-4 rounded-2xl border focus:border-red-300 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Contact Number</label>
                        <input id="bulk-phone" type="tel" value="9876543210" required
                               class="w-full px-6 py-4 rounded-2xl border focus:border-red-300 outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium mb-2">Required Quantity (kg)</label>
                        <input id="bulk-qty" type="number" min="50" value="100" required
                               class="w-full px-6 py-4 rounded-2xl border focus:border-red-300 outline-none">
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium mb-2">Chicken Type</label>
                        <select id="bulk-type" class="w-full px-6 py-4 rounded-2xl border focus:border-red-300 outline-none">
                            <option value="Boiler">Boiler Chicken (₹200/kg)</option>
                            <option value="Hydrabadi">Hydrabadi Chicken (₹380/kg)</option>
                            <option value="Koklere">Koklere Chicken (₹180/kg)</option>
                            <option value="Gaorani">Gaorani Chicken (₹800/kg)</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium mb-2">Message / Special Request</label>
                        <textarea id="bulk-message" rows="4" placeholder="Need delivery by 7 PM tomorrow..." 
                                  class="w-full px-6 py-4 rounded-3xl border focus:border-red-300 outline-none"></textarea>
                    </div>
                </div>
                
                <button type="submit"
                        class="mt-8 w-full py-6 bg-gradient-to-r from-red-600 to-red-700 text-white font-bold text-2xl rounded-3xl hover:scale-[1.02] transition">
                    Submit Bulk Order Request
                </button>
                <p class="text-center text-xs text-gray-400 mt-4">Our team will contact you within 1 hour</p>
            </form>
        </div>
    </section>

    <!-- CONSUMER / CUSTOMER DASHBOARD -->
    <section id="consumer-dashboard" class="section">
        <div class="max-w-7xl mx-auto px-6 py-12">
            <div class="flex justify-between items-end mb-8">
                <div>
                    <h1 class="text-4xl font-bold">Welcome back, Aryan!</h1>
                    <p class="text-gray-500">Consumer Dashboard • Shakil Chicken Shop Chimur</p>
                </div>
                <div class="text-right">
                    <div class="text-sm text-gray-500">Member since</div>
                    <div class="font-semibold">March 2025</div>
                </div>
            </div>
            
            <div class="grid md:grid-cols-3 gap-6">
                <div class="bg-white rounded-3xl p-8 shadow">
                    <div class="flex justify-between">
                        <div>
                            <p class="text-red-600 text-sm font-semibold">TOTAL ORDERS</p>
                            <p id="total-orders-count" class="text-7xl font-bold text-red-600">8</p>
                        </div>
                        <i class="fas fa-receipt text-7xl text-red-200"></i>
                    </div>
                </div>
                <div class="bg-white rounded-3xl p-8 shadow">
                    <div class="flex justify-between">
                        <div>
                            <p class="text-emerald-600 text-sm font-semibold">FAVOURITE</p>
                            <p class="text-7xl font-bold">Gaorani</p>
                        </div>
                        <i class="fas fa-heart text-7xl text-red-200"></i>
                    </div>
                </div>
                <div onclick="navigateTo('orders')" class="bg-white rounded-3xl p-8 shadow cursor-pointer hover:shadow-xl transition">
                    <div class="flex justify-between">
                        <div>
                            <p class="text-amber-600 text-sm font-semibold">LAST ORDER</p>
                            <p class="text-lg font-semibold">12 Mar 2025 • Boiler 5kg</p>
                        </div>
                        <i class="fas fa-clock text-7xl text-amber-200"></i>
                    </div>
                </div>
            </div>
            
            <div class="mt-12">
                <h3 class="font-semibold mb-4">Recent Orders</h3>
                <div id="consumer-recent-orders" class="space-y-4">
                    <!-- JS populated -->
                </div>
            </div>
        </div>
    </section>

    <!-- ADMIN SECTION -->
    <section id="admin-panel" class="section">
        <div class="max-w-7xl mx-auto px-6 py-12">
            <div class="flex items-center justify-between mb-8">
                <h1 class="text-4xl font-bold flex items-center gap-3">
                    <i class="fas fa-crown"></i> Admin Panel
                </h1>
                <div class="px-6 py-3 bg-amber-100 text-amber-700 rounded-3xl text-sm font-semibold">Logged in as AGD (Owner)</div>
            </div>
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <!-- Stats -->
                <div class="lg:col-span-12 grid grid-cols-2 md:grid-cols-4 gap-6">
                    <div class="bg-white p-6 rounded-3xl flex items-center gap-5 shadow">
                        <div class="flex-1">
                            <p class="uppercase text-xs tracking-widest">Today's Revenue</p>
                            <p class="text-4xl font-bold">₹12,840</p>
                        </div>
                        <i class="fas fa-rupee-sign text-5xl text-green-500"></i>
                    </div>
                    <div class="bg-white p-6 rounded-3xl flex items-center gap-5 shadow">
                        <div class="flex-1">
                            <p class="uppercase text-xs tracking-widest">Orders Today</p>
                            <p class="text-4xl font-bold">14</p>
                        </div>
                        <i class="fas fa-box text-5xl text-blue-500"></i>
                    </div>
                    <div class="bg-white p-6 rounded-3xl flex items-center gap-5 shadow">
                        <div class="flex-1">
                            <p class="uppercase text-xs tracking-widest">Stock (kg)</p>
                            <p class="text-4xl font-bold">248</p>
                        </div>
                        <i class="fas fa-drumstick-bite text-5xl text-purple-500"></i>
                    </div>
                    <div class="bg-white p-6 rounded-3xl flex items-center gap-5 shadow">
                        <div class="flex-1">
                            <p class="uppercase text-xs tracking-widest">Pending Bulk</p>
                            <p class="text-4xl font-bold">3</p>
                        </div>
                        <i class="fas fa-truck-loading text-5xl text-orange-500"></i>
                    </div>
                </div>
                
                <!-- Manage Orders -->
                <div class="lg:col-span-8 bg-white rounded-3xl shadow p-8">
                    <h3 class="font-semibold text-lg mb-5 flex items-center gap-2"><i class="fas fa-list"></i> Recent Orders (Admin View)</h3>
                    <div id="admin-orders-table" class="overflow-auto">
                        <!-- JS populated -->
                    </div>
                </div>
                
                <!-- Quick Actions -->
                <div class="lg:col-span-4 space-y-6">
                    <div onclick="fakeAddStock()" class="bg-white rounded-3xl p-8 cursor-pointer hover:bg-red-50 transition">
                        <h4 class="font-semibold mb-1">Add Stock</h4>
                        <p class="text-sm text-gray-500">Update inventory instantly</p>
                        <div class="mt-6 text-6xl font-bold text-red-600">+50 kg</div>
                    </div>
                    
                    <div onclick="showAllProductsAdmin()" class="bg-white rounded-3xl p-8 cursor-pointer hover:bg-red-50 transition">
                        <h4 class="font-semibold mb-1">Update Prices</h4>
                        <p class="text-sm text-gray-500">Change rates for all chicken types</p>
                    </div>
                    
                    <div class="bg-red-50 text-red-700 rounded-3xl p-8 text-center cursor-pointer" onclick="alert('✅ Notification sent to all customers!')">
                        <i class="fas fa-bullhorn text-4xl mb-4"></i>
                        <p class="font-semibold">Send Promotion to Customers</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- LOGIN MODAL -->
    <div id="login-modal" onclick="if(event.target===this)hideLoginModal()" 
         class="hidden fixed inset-0 bg-black/70 z-[9999] flex items-center justify-center">
        <div onclick="event.stopImmediatePropagation()" 
             class="modal bg-white rounded-3xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
            <div class="px-8 pt-8 pb-2">
                <h2 class="text-3xl font-bold text-center mb-8">Welcome to Shakil Chicken</h2>
                
                <div class="flex border-b mb-6">
                    <button onclick="switchTab(0)" id="tab-customer"
                            class="flex-1 py-4 font-semibold text-red-600 border-b-4 border-red-600">Customer Login</button>
                    <button onclick="switchTab(1)" id="tab-admin"
                            class="flex-1 py-4 font-semibold text-gray-400">Admin Login</button>
                </div>
                
                <div class="space-y-6">
                    <div>
                        <label class="text-xs font-medium text-gray-500">Username</label>
                        <input id="login-username" type="text" value="AGD" 
                               class="w-full px-6 py-4 border rounded-2xl focus:border-red-300">
                    </div>
                    <div>
                        <label class="text-xs font-medium text-gray-500">Password</label>
                        <input id="login-password" type="password" value="12345" 
                               class="w-full px-6 py-4 border rounded-2xl focus:border-red-300">
                    </div>
                    
                    <button onclick="handleLogin()" 
                            class="w-full py-6 bg-red-600 text-white font-bold text-xl rounded-3xl">Login Securely</button>
                    
                    <p onclick="registerDemo()" class="text-center text-sm text-red-600 cursor-pointer hover:underline">
                        New customer? Register in 10 seconds (demo)
                    </p>
                </div>
            </div>
            
            <div class="bg-gray-100 px-8 py-6 text-xs flex justify-center gap-8 text-gray-500">
                <div class="flex items-center gap-2"><i class="fas fa-lock"></i> Secure</div>
                <div class="flex items-center gap-2"><i class="fas fa-user-shield"></i> AGD / 12345 ready</div>
            </div>
        </div>
    </div>

    <script>
        // Tailwind script initialization
        function initTailwind() {
            tailwind.config = {
                content: [],
                theme: {
                    extend: {}
                }
            }
        }
        
        // Global state
        let currentUser = null
        let isAdmin = false
        let cart = []
        let orders = []
        let bulkRequests = []
        
        // Products data
        const products = [
            {
                id: 1,
                name: "Boiler Chicken",
                price: 200,
                unit: "kg",
                desc: "Fresh farm-raised broiler, perfect for daily cooking",
                img: "🐔"
            },
            {
                id: 2,
                name: "Hydrabadi Chicken",
                price: 380,
                unit: "kg",
                desc: "Spicy Hyderabadi breed, rich flavour & tender meat",
                img: "🌶️🐔"
            },
            {
                id: 3,
                name: "Koklere Chicken",
                price: 180,
                unit: "kg",
                desc: "Budget friendly, juicy & great for curries",
                img: "🐔"
            },
            {
                id: 4,
                name: "Gaorani Chicken",
                price: 800,
                unit: "kg",
                desc: "Premium free-range desi chicken, highest quality",
                img: "🏆🐔"
            }
        ]
        
        // Sample pre-registered user (AGD / 12345)
        function getStoredUsers() {
            return {
                AGD: {
                    password: "12345",
                    name: "Aryan",
                    role: "customer",
                    joined: "2025-03-01"
                }
            }
        }
        
        // Render products on shop page
        function renderProducts() {
            const container = document.getElementById("products-grid")
            container.innerHTML = ""
            
            products.forEach(product => {
                const cardHTML = `
                <div class="product-card bg-white rounded-3xl shadow p-6 border border-transparent">
                    <div class="text-6xl mb-4">${product.img}</div>
                    <h3 class="font-semibold text-xl">${product.name}</h3>
                    <p class="text-gray-500 text-sm mb-4">${product.desc}</p>
                    <div class="flex justify-between items-end">
                        <div>
                            <span class="text-4xl font-bold text-red-600">₹${product.price}</span>
                            <span class="text-xs text-gray-400">/${product.unit}</span>
                        </div>
                        <div class="flex items-center border rounded-3xl">
                            <button onclick="addToCart(${product.id}, -1)" class="w-8 h-8 flex items-center justify-center text-xl font-bold text-red-600">-</button>
                            <input id="qty-${product.id}" type="number" value="1" min="0.5" step="0.5" 
                                   class="w-12 text-center bg-transparent outline-none text-sm font-medium">
                            <button onclick="addToCart(${product.id}, 1)" class="w-8 h-8 flex items-center justify-center text-xl font-bold text-red-600">+</button>
                        </div>
                        <button onclick="addToCart(${product.id}, parseFloat(document.getElementById('qty-${product.id}').value))" 
                                class="bg-red-600 text-white px-6 py-2 rounded-3xl text-sm font-medium">Add</button>
                    </div>
                </div>`
                container.innerHTML += cardHTML
            })
        }
        
        // Featured products on home
        function renderFeatured() {
            const container = document.getElementById("featured-products")
            container.innerHTML = products.map(p => `
                <div onclick="navigateTo('shop')" class="bg-white rounded-3xl p-6 text-center cursor-pointer hover:shadow-xl transition">
                    <div class="text-7xl mb-4">${p.img}</div>
                    <h4 class="font-semibold">${p.name}</h4>
                    <p class="text-red-600 font-bold">₹${p.price}/kg</p>
                </div>
            `).join("")
        }
        
        // Add item to cart
        function addToCart(id, qty) {
            const product = products.find(p => p.id === id)
            if (!product) return
            
            if (qty < 0.5) {
                alert("Minimum 0.5 kg allowed")
                return
            }
            
            const existing = cart.find(item => item.id === id)
            if (existing) {
                existing.qty += qty
            } else {
                cart.push({
                    ...product,
                    qty: qty
                })
            }
            
            saveCart()
            updateCartCount()
            
            // Nice toast
            const toast = document.createElement("div")
            toast.style.cssText = "position:fixed; bottom:20px; right:20px; background:#d32f2f; color:white; padding:16px 24px; border-radius:9999px; box-shadow:0 10px 15px -3px rgb(0 0 0 / 0.2);"
            toast.innerHTML = `✅ ${qty} kg ${product.name} added to cart`
            document.body.appendChild(toast)
            setTimeout(() => toast.remove(), 2500)
            
            if (document.getElementById("cart").classList.contains("active")) renderCart()
        }
        
        function saveCart() {
            localStorage.setItem("shakilCart", JSON.stringify(cart))
        }
        
        function loadCart() {
            const saved = localStorage.getItem("shakilCart")
            if (saved) cart = JSON.parse(saved)
        }
        
        function updateCartCount() {
            const countEl = document.getElementById("cart-count")
            let totalItems = 0
            cart.forEach(item => totalItems += item.qty)
            countEl.textContent = totalItems
        }
        
        function renderCart() {
            const container = document.getElementById("cart-items")
            const empty = document.getElementById("cart-empty")
            const content = document.getElementById("cart-content")
            
            if (cart.length === 0) {
                empty.classList.remove("hidden")
                content.classList.add("hidden")
                return
            }
            
            empty.classList.add("hidden")
            content.classList.remove("hidden")
            
            let html = ""
            let total = 0
            
            cart.forEach((item, index) => {
                const subtotal = item.price * item.qty
                total += subtotal
                html += `
                <tr>
                    <td class="py-6 flex items-center gap-4">
                        <span class="text-4xl">${item.img}</span>
                        <div>
                            <div class="font-medium">${item.name}</div>
                            <div class="text-xs text-gray-400">${item.desc}</div>
                        </div>
                    </td>
                    <td class="py-6">${item.qty} kg</td>
                    <td class="py-6">₹${item.price}</td>
                    <td class="py-6 text-right font-semibold">₹${subtotal}</td>
                    <td class="py-6">
                        <button onclick="removeFromCart(${index})" class="text-red-400 hover:text-red-600"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>`
            })
            
            container.innerHTML = html
            document.getElementById("cart-total").innerHTML = `₹${Math.round(total * 1.05)} <span class="text-sm font-normal text-gray-400">(incl. GST)</span>`
        }
        
        function removeFromCart(index) {
            cart.splice(index, 1)
            saveCart()
            renderCart()
            updateCartCount()
        }
        
        // Proceed to checkout
        function proceedToCheckout() {
            if (cart.length === 0) return
            navigateTo("checkout")
            renderCheckoutSummary()
        }
        
        function renderCheckoutSummary() {
            let subtotal = 0
            let html = ""
            
            cart.forEach(item => {
                const sub = item.price * item.qty
                subtotal += sub
                html += `
                <div class="flex justify-between items-center">
                    <div class="flex items-center gap-3">
                        <span class="text-3xl">${item.img}</span>
                        <div>${item.name} × ${item.qty} kg</div>
                    </div>
                    <div class="font-medium">₹${sub}</div>
                </div>`
            })
            
            const gst = Math.round(subtotal * 0.05)
            const final = subtotal + gst
            
            document.getElementById("checkout-items").innerHTML = html
            document.getElementById("subtotal").textContent = `₹${subtotal}`
            document.getElementById("gst").textContent = `₹${gst}`
            document.getElementById("final-total").innerHTML = `<span class="text-red-600">₹${final}</span>`
            document.getElementById("checkout-total").textContent = final
        }
        
        // Place order
        function placeOrder(e) {
            e.preventDefault()
            
            const total = parseFloat(document.getElementById("final-total").textContent.replace("₹", ""))
            
            const newOrder = {
                id: "ORD-" + Math.floor(100000 + Math.random() * 900000),
                date: new Date().toLocaleDateString('en-IN'),
                items: [...cart],
                total: total,
                status: "Confirmed",
                address: document.getElementById("address").value
            }
            
            orders.unshift(newOrder)
            localStorage.setItem("shakilOrders", JSON.stringify(orders))
            
            // Clear cart
            cart = []
            saveCart()
            updateCartCount()
            
            alert(`🎉 Order placed successfully!\nOrder ID: ${newOrder.id}\nTotal: ₹${total}\nThank you for shopping at Shakil Chicken Shop Chimur!`)
            
            navigateTo("orders")
        }
        
        // Render orders (customer view)
        function renderOrders() {
            const container = document.getElementById("orders-list")
            if (orders.length === 0) {
                container.innerHTML = `<div class="text-center py-20 bg-white rounded-3xl"><i class="fas fa-receipt text-8xl text-gray-200"></i><p class="mt-6 font-medium">No orders yet. Start shopping!</p></div>`
                return
            }
            
            let html = ""
            orders.forEach(order => {
                html += `
                <div class="bg-white rounded-3xl p-6 flex flex-col md:flex-row gap-6">
                    <div class="flex-1">
                        <div class="flex justify-between">
                            <span class="font-mono text-red-600">${order.id}</span>
                            <span class="text-xs px-4 py-1 bg-emerald-100 text-emerald-700 rounded-3xl">${order.status}</span>
                        </div>
                        <p class="text-sm text-gray-400">${order.date}</p>
                        
                        <div class="mt-4 flex flex-wrap gap-4">
                            ${order.items.map(item => `<div class="text-sm">${item.img} ${item.name} × ${item.qty}kg</div>`).join("")}
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-3xl font-bold">₹${order.total}</div>
                        <div class="text-xs text-gray-400">Cash on Delivery</div>
                    </div>
                </div>`
            })
            container.innerHTML = html
        }
        
        // Render recent orders for consumer dashboard
        function renderConsumerRecent() {
            const container = document.getElementById("consumer-recent-orders")
            const recent = orders.slice(0, 3)
            
            if (recent.length === 0) {
                container.innerHTML = `<p class="text-gray-400 italic">Your recent orders will appear here</p>`
                return
            }
            
            let html = ""
            recent.forEach(o => {
                html += `<div class="flex justify-between items-center bg-white p-5 rounded-2xl"><div><span class="font-mono">${o.id}</span> • ${o.date}</div><div class="font-bold">₹${o.total}</div></div>`
            })
            container.innerHTML = html
        }
        
        // Admin orders table
        function renderAdminOrders() {
            const container = document.getElementById("admin-orders-table")
            let html = `<table class="w-full text-sm"><thead><tr class="text-gray-400 border-b"><th class="text-left py-4">Order ID</th><th class="text-left py-4">Date</th><th class="text-left py-4">Customer</th><th class="text-left py-4">Total</th><th class="text-left py-4">Status</th></tr></thead><tbody>`
            
            orders.forEach(order => {
                html += `<tr class="border-b"><td class="py-4 font-mono">${order.id}</td><td class="py-4">${order.date}</td><td class="py-4">AGD</td><td class="py-4 font-semibold">₹${order.total}</td><td class="py-4"><span class="px-3 py-px text-xs bg-green-100 text-green-700 rounded-3xl">${order.status}</span></td></tr>`
            })
            
            if (orders.length === 0) html += `<tr><td colspan="5" class="py-12 text-center text-gray-400">No orders yet</td></tr>`
            
            html += `</tbody></table>`
            container.innerHTML = html
        }
        
        // Handle login
        function handleLogin() {
            const username = document.getElementById("login-username").value.toUpperCase()
            const password = document.getElementById("login-password").value
            const users = getStoredUsers()
            
            if (users[username] && users[username].password === password) {
                currentUser = username
                isAdmin = document.getElementById("tab-admin").classList.contains("border-b-4")
                
                hideLoginModal()
                document.getElementById("login-btn").classList.add("hidden")
                document.getElementById("logout-btn").classList.remove("hidden")
                document.getElementById("user-avatar").classList.remove("hidden")
                document.getElementById("user-avatar").textContent = username[0]
                
                // Mobile
                document.getElementById("mobile-login-btn").classList.add("hidden")
                document.getElementById("mobile-logout-btn").classList.remove("hidden")
                
                // Show correct dashboard
                if (isAdmin) {
                    navigateTo("admin-panel")
                } else {
                    navigateTo("consumer-dashboard")
                    renderConsumerRecent()
                }
                
                // Save to localStorage
                localStorage.setItem("shakilLoggedUser", username)
                localStorage.setItem("shakilIsAdmin", isAdmin)
                
            } else {
                alert("❌ Wrong credentials!\n\nDemo: Username → AGD\nPassword → 12345")
            }
        }
        
        function switchTab(n) {
            const customerTab = document.getElementById("tab-customer")
            const adminTab = document.getElementById("tab-admin")
            
            if (n === 0) {
                customerTab.classList.add("border-b-4", "border-red-600", "text-red-600")
                customerTab.classList.remove("text-gray-400")
                adminTab.classList.remove("border-b-4", "border-red-600", "text-red-600")
                adminTab.classList.add("text-gray-400")
            } else {
                adminTab.classList.add("border-b-4", "border-red-600", "text-red-600")
                adminTab.classList.remove("text-gray-400")
                customerTab.classList.remove("border-b-4", "border-red-600", "text-red-600")
                customerTab.classList.add("text-gray-400")
            }
        }
        
        function showLoginModal() {
            document.getElementById("login-modal").classList.remove("hidden")
            document.getElementById("login-modal").classList.add("flex")
        }
        
        function hideLoginModal() {
            const modal = document.getElementById("login-modal")
            modal.classList.add("hidden")
            modal.classList.remove("flex")
        }
        
        // Demo registration
        function registerDemo() {
            hideLoginModal()
            setTimeout(() => {
                alert("✅ Account created!\n\nYou are now registered as Aryan (AGD)\nUsername: AGD\nPassword: 12345\n\nYou can login immediately.")
                showLoginModal()
            }, 300)
        }
        
        function logout() {
            currentUser = null
            isAdmin = false
            localStorage.removeItem("shakilLoggedUser")
            localStorage.removeItem("shakilIsAdmin")
            
            document.getElementById("login-btn").classList.remove("hidden")
            document.getElementById("logout-btn").classList.add("hidden")
            document.getElementById("user-avatar").classList.add("hidden")
            
            document.getElementById("mobile-login-btn").classList.remove("hidden")
            document.getElementById("mobile-logout-btn").classList.add("hidden")
            
            navigateTo("home")
        }
        
        function showProfile() {
            if (isAdmin) navigateTo("admin-panel")
            else navigateTo("consumer-dashboard")
        }
        
        // Submit bulk order
        function submitBulkOrder(e) {
            e.preventDefault()
            const data = {
                id: "BULK-" + Date.now().toString().slice(-6),
                name: document.getElementById("bulk-name").value,
                phone: document.getElementById("bulk-phone").value,
                qty: document.getElementById("bulk-qty").value,
                type: document.getElementById("bulk-type").value,
                message: document.getElementById("bulk-message").value,
                date: new Date().toLocaleDateString('en-IN')
            }
            bulkRequests.unshift(data)
            localStorage.setItem("shakilBulk", JSON.stringify(bulkRequests))
            
            alert(`🚀 Bulk order request #${data.id} submitted successfully!\nOur team will call you on ${data.phone} within 60 minutes.`)
            e.target.reset()
            navigateTo("home")
        }
        
        // Fake functions for admin
        function fakeAddStock() {
            alert("✅ Stock updated +50 kg for all items")
        }
        
        function showAllProductsAdmin() {
            let msg = "Current Prices:\n\n"
            products.forEach(p => msg += `${p.name} → ₹${p.price}/kg\n`)
            msg += "\nWould you like to update prices? (Demo only)"
            if (confirm(msg)) {
                alert("Prices updated successfully (demo)")
            }
        }
        
        // Navigation helper
        function navigateTo(section) {
            document.querySelectorAll(".section").forEach(s => s.classList.remove("active"))
            const target = document.getElementById(section)
            if (target) target.classList.add("active")
            
            // Auto render some pages
            if (section === "cart") renderCart()
            if (section === "orders") renderOrders()
            if (section === "admin-panel") renderAdminOrders()
        }
        
        function toggleMobileMenu() {
            const menu = document.getElementById("mobile-menu")
            const icon = document.getElementById("mobile-icon")
            if (menu.classList.contains("hidden")) {
                menu.style.display = "block"
                icon.classList.replace("fa-bars", "fa-xmark")
            } else {
                menu.style.display = "none"
                icon.classList.replace("fa-xmark", "fa-bars")
            }
        }
        
        // Main initialization
        function initializeWebsite() {
            initTailwind()
            loadCart()
            updateCartCount()
            renderProducts()
            renderFeatured()
            
            // Load saved orders & bulk
            const savedOrders = localStorage.getItem("shakilOrders")
            if (savedOrders) orders = JSON.parse(savedOrders)
            
            const savedBulk = localStorage.getItem("shakilBulk")
            if (savedBulk) bulkRequests = JSON.parse(savedBulk)
            
            // Auto-login if saved session
            const savedUser = localStorage.getItem("shakilLoggedUser")
            if (savedUser) {
                currentUser = savedUser
                isAdmin = localStorage.getItem("shakilIsAdmin") === "true"
                
                document.getElementById("login-btn").classList.add("hidden")
                document.getElementById("logout-btn").classList.remove("hidden")
                document.getElementById("user-avatar").classList.remove("hidden")
                document.getElementById("user-avatar").innerHTML = savedUser[0]
                
                // Mobile buttons
                document.getElementById("mobile-login-btn").classList.add("hidden")
                document.getElementById("mobile-logout-btn").classList.remove("hidden")
                
                // Show appropriate dashboard on reload
                if (window.location.hash === "#admin") {
                    navigateTo("admin-panel")
                } else if (isAdmin) {
                    navigateTo("admin-panel")
                } else {
                    navigateTo("consumer-dashboard")
                    renderConsumerRecent()
                }
            }
            
            console.log("%c✅ Shakil Chicken Shop Chimur website ready! 🎉", "background:#d32f2f;color:white;padding:2px 6px;border-radius:4px")
            console.log("Pre-registered user: AGD / 12345 (works for both Customer & Admin)")
        }
        
        // Start the website
        window.onload = initializeWebsite
    </script>
</body>
</html>
